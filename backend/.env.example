# ──────────────────────────────────────────────────────────────────────────
# InfluxDB Dashboard — backend configuration
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
# ──────────────────────────────────────────────────────────────────────────

# InfluxDB connection settings (read server-side ONLY, never sent to browser)
INFLUXDB_URL=http://134.141.1.115:8086
INFLUXDB_USERNAME=extreme
INFLUXDB_PASSWORD=Extr3m3!
INFLUXDB_ORG=
INFLUXDB_TOKEN=

# Secret used to sign session JWTs. Generate a strong random value in prod:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# How long an authenticated session lasts, in hours.
SESSION_TTL_HOURS=8

# Server-side cache TTL for fetched data, in seconds (default 5 min).
CACHE_TTL_SECONDS=300

# Backend listen port and environment.
API_PORT=3001
FLASK_ENV=development

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional HTTP Basic perimeter gate. Enforced only when BOTH are set.
# Leave unset for local/demo dev; set both on any public deployment.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
